{
  "name": "media-processing-server",
  "version": "1.0.0",
  "description": "Backend API and worker for asynchronous AI media processing pipeline",
  "main": "src/index.js",
  "scripts": {
    "start:api": "node src/index.js",
    "start:worker": "node src/worker/worker.js",
    "dev:api": "nodemon src/index.js",
    "dev:worker": "nodemon src/worker/worker.js",
    "test": "jest --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.2",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.3",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000
  }
