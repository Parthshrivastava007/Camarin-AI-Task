# Application configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGO_URI=mongodb://localhost:27017/media-processor

# Queue configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security credentials
JWT_SECRET=your_jwt_signing_secret_here
JWT_EXPIRES_IN=24h

# AI API Keys (Leave blank to run in Mock Mode)
HF_API_TOKEN=your_hugging_face_inference_token
GOOGLE_API_KEY=your_google_cloud_vision_api_key
